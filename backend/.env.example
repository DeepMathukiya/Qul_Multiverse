# Backend service environment variables.
# Copy to backend/.env and adjust. Values here override backend/config.yaml.

# Server binding
BACKEND_HOST=0.0.0.0
BACKEND_PORT=5000

# Datascience processing service
DATASCIENCE_URL=http://127.0.0.1:8100
PROCESS_TIMEOUT_SEC=120

# Camera role mapping (device_id values sent by the phone app)
VERTICAL_DEVICE_ID=vertical
HORIZONTAL_DEVICE_ID=horizontal

# Continuous streaming mode (auto-inspect the live pair in a loop)
CONTINUOUS_ENABLED=true
CONTINUOUS_INTERVAL_SEC=5
