<?xml version="1.0" encoding="utf-8"?>
<!-- Allows plain HTTP to your local ML backend (e.g. http://192.168.x.x:5000).
     Tighten this before shipping outside a hackathon/demo setting. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
