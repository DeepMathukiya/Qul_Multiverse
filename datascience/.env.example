# Datascience service environment variables.
# Copy to datascience/.env and adjust. Values here override
# datascience/config/processing_config.yaml.

# Qwen3-VL-4B-Instruct served locally via Qualcomm GenieX
# (install GenieX, `geniex pull ai-hub-models/Qwen3-VL-4B-Instruct`,
# `geniex serve`). Used for OCR field extraction and pothole detection;
# without it reachable, OCR/pothole report NOT_AVAILABLE.
GENIEX_BASE_URL=http://127.0.0.1:18181/v1
GENIEX_MODEL=ai-hub-models/Qwen3-VL-4B-Instruct
# GenieX is a local server and typically ignores the key, but the openai
# SDK requires a non-empty string.
GENIEX_API_KEY=not-needed-local

# Server binding
DATASCIENCE_HOST=127.0.0.1
DATASCIENCE_PORT=8100

# Optional overrides
# MM_PER_PX=0.25
