# Datascience service environment variables.
# Copy to datascience/.env and adjust. Values here override
# datascience/config/processing_config.yaml.

# Sarvam AI OCR (required for OCR; without it OCR reports NOT_AVAILABLE)
SARVAM_API_KEY=your_sarvam_api_key_here

# Server binding
DATASCIENCE_HOST=127.0.0.1
DATASCIENCE_PORT=8100

# Optional overrides
# POTHOLE_WEIGHTS_PATH=models/pothole_yolov8_seg.pt
# MM_PER_PX=0.25
